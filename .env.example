# Braindance admin-app / VPS environment.
# Copy to /srv/.env on the host, `chmod 600`, and fill in real values.
# Consumed two ways (see docker-compose.yml and deploy.sh):
#   - Compose ${VAR} interpolation, via ./deploy.sh (--env-file /srv/.env)
#   - Container runtime env, via each service's `env_file: /srv/.env`

# --- Public site config (Compose interpolation + Caddy {$DOMAIN}) ---
DOMAIN=example.com
API_IMAGE=ghcr.io/OWNER/REPO/api:latest

# --- Mobile API secrets (api container runtime) ---
GITHUB_REPO=OWNER/REPO
GITHUB_TOKEN=ghp_your_pat_here
