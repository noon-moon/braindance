# Working repos — cloned here locally, never tracked
repo/

# Non-persisted inputs for consideration — dropped in per task, never tracked
# (the explanatory README is the one tracked file)
ctx/inputs/*
!ctx/inputs/README.md

# Non-persisted outputs — agent work products that don't belong in the vault
ctx/outputs/*
!ctx/outputs/README.md

# Harness-generated sync targets (created by ctx/tools/sys/sync.sh)
.claude/
.cursor/

# Node
node_modules/
api/dist/

# Host secrets — the real one lives at /srv/.env, never in the repo
.env

# OS
.DS_Store
Thumbs.db
