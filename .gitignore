# Working repos — cloned here locally, never tracked
repo/

# Ephemeral scratch — non-persisted things, never tracked. Lives inside the
# vault so Obsidian can see it; scoped to the _ephemeral/ subfolder so real
# vault notes stay tracked. (The explanatory README is the one tracked file.)
# This root rule also holds in a personal fork that un-ignores its vault notes.
ctx/vault/_ephemeral/*
!ctx/vault/_ephemeral/README.md

# Harness-generated sync targets (created by ctx/tools/sys/sync.sh)
.claude/
.cursor/

# Node
node_modules/
api/dist/

# GitHub Pages / Quartz garden build artifacts — regenerated by the pages
# workflow (and local `quartz build`); never committed. node_modules is covered
# above. The tool-generated content (ctx/www/garden/content/<slug>.md) IS tracked
# — it's the reviewed public projection — so it is deliberately NOT ignored here.
ctx/www/garden/public/
ctx/www/garden/.quartz/
ctx/www/garden/.quartz-cache/
_site/

# Host secrets — the real one lives at /srv/.env, never in the repo
.env

# OS
.DS_Store
Thumbs.db
